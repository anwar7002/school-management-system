{
  "name": "@school/db",
  "version": "1.0.0",
  "description": "Database schema and migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate": "drizzle-kit generate:pg --config=drizzle.config.ts",
    "migrate": "drizzle-kit migrate:pg --config=drizzle.config.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "drizzle-kit": "^0.20.7",
    "typescript": "^5.3.3"
  }
}
